---
interface Props {
  title: string;
  body: string;
  href: string;
}

const { href, title, body } = Astro.props;
---

<li
  class="flex items-center bg-slate-600 h-full rounded-lg p-4 text-slate-50 leading-6 drop-shadow-lg"
>
  <a href={href}>
    <h2 class="text-2xl font-bold">
      {title}
      <span>&rarr;</span>
    </h2>
    <p>
      {body}
    </p>
  </a>
</li>
