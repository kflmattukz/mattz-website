---
interface Project {
  title: string;
  desc: string;
  img?: string;
}

const projects: Project[] = [
  {
    title: "Social Media Client",
    desc: "I'm learning backend using express js and i make app Social media clone using express and view using pug to render the view",
    img: "",
  },
  {
    title: "Redesign CODE ID website (Bootcamp final project)",
    desc: "I'm learning make a backend using Nest JS and frontend using Next JS, i make the user profile and Curriculum section on the app",
    img: "",
  },
  {
    title: "Fleet Web app (My first project as Profesional Software Engineer)",
    desc: "I'm learning make a backend using Nest JS and frontend using Next JS, i make the user profile and Curriculum section on the app",
    img: "",
  },
];
---

<main class="mx-auto mt-5 max-w-[600px]">
  <h2 class="section-title text-3xl font-semibold tracking-wide text-slate-700">
    Projects
  </h2>
  <div class="grid gap-3 p-3 sm:grid-cols-2">
    {
      projects.map(
        (project): Project => (
          <div class=" card rounded-xl bg-slate-50 p-3 shadow-sm ring-1 ring-slate-400/25 duration-300 hover:scale-105 hover:shadow-md">
            <h3 class="text-xl font-semibold tracking-wide text-slate-700">
              {project.title}
            </h3>
            <p>{project.desc}</p>
          </div>
        ),
      )
    }
  </div>
</main>
